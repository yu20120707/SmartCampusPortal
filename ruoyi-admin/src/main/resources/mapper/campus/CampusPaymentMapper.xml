<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.campus.payment.mapper.CampusPaymentMapper">

    <resultMap type="CampusPaymentItem" id="CampusPaymentItemResult">
        <result property="itemId" column="item_id" />
        <result property="userId" column="user_id" />
        <result property="itemNo" column="item_no" />
        <result property="itemName" column="item_name" />
        <result property="itemType" column="item_type" />
        <result property="amount" column="amount" />
        <result property="status" column="status" />
        <result property="dueDate" column="due_date" />
        <result property="createBy" column="create_by" />
        <result property="createTime" column="create_time" />
        <result property="updateBy" column="update_by" />
        <result property="updateTime" column="update_time" />
        <result property="remark" column="remark" />
    </resultMap>

    <resultMap type="CampusPaymentRecord" id="CampusPaymentRecordResult">
        <result property="recordId" column="record_id" />
        <result property="itemId" column="item_id" />
        <result property="userId" column="user_id" />
        <result property="paymentNo" column="payment_no" />
        <result property="itemName" column="item_name" />
        <result property="itemType" column="item_type" />
        <result property="amount" column="amount" />
        <result property="channel" column="channel" />
        <result property="status" column="status" />
        <result property="paidTime" column="paid_time" />
        <result property="createBy" column="create_by" />
        <result property="createTime" column="create_time" />
        <result property="updateBy" column="update_by" />
        <result property="updateTime" column="update_time" />
        <result property="remark" column="remark" />
    </resultMap>

    <sql id="itemColumns">
        item_id, user_id, item_no, item_name, item_type, amount, status, due_date,
        create_by, create_time, update_by, update_time, remark
    </sql>

    <select id="selectPendingItemsByUserId" parameterType="Long" resultMap="CampusPaymentItemResult">
        select <include refid="itemColumns" />
        from campus_payment_item
        where user_id = #{userId}
          and status = 'unpaid'
        order by due_date, item_id
    </select>

    <select id="selectRecordsByUserId" parameterType="Long" resultMap="CampusPaymentRecordResult">
        select record_id, item_id, user_id, payment_no, item_name, item_type, amount, channel, status,
               paid_time, create_by, create_time, update_by, update_time, remark
        from campus_payment_record
        where user_id = #{userId}
        order by paid_time desc, record_id desc
    </select>

    <select id="selectPendingItemForUpdate" resultMap="CampusPaymentItemResult">
        select <include refid="itemColumns" />
        from campus_payment_item
        where item_id = #{itemId}
          and user_id = #{userId}
          and status = 'unpaid'
        for update
    </select>

    <update id="markItemPaid">
        update campus_payment_item
        set status = 'paid',
            update_by = #{updateBy},
            update_time = sysdate()
        where item_id = #{itemId}
          and user_id = #{userId}
          and status = 'unpaid'
    </update>

    <insert id="insertRecord" parameterType="CampusPaymentRecord" useGeneratedKeys="true" keyProperty="recordId">
        insert into campus_payment_record(
            item_id, user_id, payment_no, item_name, item_type, amount, channel,
            status, paid_time, create_by, create_time, remark
        ) values (
            #{itemId}, #{userId}, #{paymentNo}, #{itemName}, #{itemType}, #{amount}, #{channel},
            #{status}, #{paidTime}, #{createBy}, sysdate(), #{remark}
        )
    </insert>
</mapper>
